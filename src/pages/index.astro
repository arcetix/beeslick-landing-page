---
const pageTitle = "Beeslick | AI-native messaging for modern teams";
const pageDescription =
  "Beeslick is the shared workspace where people, agents, channels, threads, and direct messages move work together.";
const fallbackSiteUrl = "https://beeslick.ai";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? fallbackSiteUrl).toString();
const socialImagePath = "/images/beeslick-share-card.svg";
const socialImageUrl = new URL(socialImagePath, Astro.site ?? fallbackSiteUrl).toString();

const chips = ["AI teammates", "Channels", "Threads", "DMs", "Context memory", "Fast decisions"];
const problemTiles = [
  { label: "Apps", icon: "browser", tone: "muted" },
  { label: "Direct messages", icon: "inboxes", tone: "focus" },
  { label: "Docs", icon: "document", tone: "muted" },
  { label: "Channels", icon: "legacy", tone: "focus" },
  { label: "Teammate", icon: "person", tone: "center" },
  { label: "AI agents", icon: "globe", tone: "focus" },
  { label: "Calls", icon: "phone", tone: "muted" },
  { label: "Tasks", icon: "sheets", tone: "focus" },
  { label: "Chat", icon: "chat", tone: "muted" },
];
const problemIcons = {
  browser:
    '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8.25V18a2.25 2.25 0 0 0 2.25 2.25h13.5A2.25 2.25 0 0 0 21 18V8.25m-18 0V6a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 6v2.25m-18 0h18M5.25 6h.01M7.5 6h.01M9.75 6h.01"/></svg>',
  inboxes:
    '<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><rect x="10" y="14" width="24" height="16" rx="2" fill="#faf9f6" stroke="rgba(4,36,43,0.55)" stroke-width="1"></rect><rect x="6" y="10" width="24" height="16" rx="2" fill="#fff" stroke="rgba(4,36,43,0.55)" stroke-width="1"></rect><path d="M6 11l12 8.5L30 11" stroke="rgba(4,36,43,0.55)" stroke-width="1" fill="none" stroke-linejoin="round"></path></svg>',
  document:
    '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625A3.375 3.375 0 0 0 16.125 8.25h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5A3.375 3.375 0 0 0 10.125 2.25H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>',
  legacy:
    '<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><rect x="5" y="8" width="30" height="20" rx="2" fill="#fff" stroke="rgba(4,36,43,0.55)" stroke-width="1"></rect><rect x="8" y="11" width="24" height="14" fill="rgba(4,36,43,0.05)"></rect><line x1="10.5" y1="14.5" x2="22" y2="14.5" stroke="rgba(4,36,43,0.55)" stroke-width="1" opacity=".7"></line><line x1="10.5" y1="17.5" x2="26" y2="17.5" stroke="rgba(4,36,43,0.55)" stroke-width="1" opacity=".7"></line><line x1="10.5" y1="20.5" x2="19" y2="20.5" stroke="rgba(4,36,43,0.55)" stroke-width="1" opacity=".7"></line><rect x="17.5" y="28" width="5" height="3" fill="rgba(4,36,43,0.55)"></rect><rect x="12" y="31" width="16" height="1.8" rx=".9" fill="rgba(4,36,43,0.55)"></rect></svg>',
  person:
    '<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="15" r="5.6" stroke="rgba(250,249,246,0.7)" stroke-width="1.2"></circle><path d="M8.5 32c0-7 4.5-10.5 11.5-10.5S31.5 25 31.5 32" stroke="rgba(250,249,246,0.7)" stroke-width="1.2" fill="none" stroke-linejoin="round" stroke-linecap="round"></path></svg>',
  globe:
    '<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="13" fill="#fff" stroke="rgba(4,36,43,0.55)" stroke-width="1"></circle><ellipse cx="20" cy="20" rx="6" ry="13" stroke="rgba(4,36,43,0.55)" stroke-width="1" opacity=".7"></ellipse><line x1="7" y1="20" x2="33" y2="20" stroke="rgba(4,36,43,0.55)" stroke-width="1" opacity=".7"></line><path d="M9 14q11 3 22 0M9 26q11-3 22 0" stroke="rgba(4,36,43,0.55)" stroke-width="1" opacity=".5" fill="none"></path><circle cx="13" cy="13.5" r="2" fill="rgba(4,36,43,0.55)"></circle><circle cx="27" cy="14" r="2" fill="rgba(4,36,43,0.55)"></circle><circle cx="20" cy="28" r="2" fill="rgba(4,36,43,0.55)"></circle></svg>',
  phone:
    '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>',
  sheets:
    '<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><rect x="5" y="7" width="30" height="26" rx="1.5" fill="#fff" stroke="rgba(4,36,43,0.55)" stroke-width="1"></rect><rect x="5" y="7" width="30" height="4.5" fill="rgba(4,36,43,0.08)"></rect><rect x="5" y="11.5" width="5" height="21.5" fill="rgba(4,36,43,0.08)"></rect><path d="M10 7v26M18 7v26M26.5 7v26M5 11.5h30M5 18h30M5 25h30" stroke="rgba(4,36,43,0.55)" stroke-width="1" opacity=".65"></path><rect x="11.5" y="14" width="5" height="1.4" fill="rgba(4,36,43,0.55)" opacity=".6"></rect><rect x="19.5" y="14" width="5" height="1.4" fill="rgba(4,36,43,0.55)" opacity=".6"></rect><rect x="28" y="14" width="5" height="1.4" fill="rgba(4,36,43,0.55)" opacity=".6"></rect><rect x="18" y="18" width="8.5" height="7" fill="rgba(4,36,43,0.06)" stroke="rgba(4,36,43,0.55)" stroke-width="1"></rect></svg>',
  chat:
    '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 0 1 1.037-.443 48.282 48.282 0 0 0 5.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/></svg>',
};
const appIcons = {
  edit: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m16.86 4.49 2.65 2.65M5 19l4.35-.9L19.4 8.05a1.87 1.87 0 0 0 0-2.65l-.8-.8a1.87 1.87 0 0 0-2.65 0L5.9 14.65 5 19Z"/></svg>',
  search: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z"/></svg>',
  plugins: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 4h2v4H6V6a2 2 0 0 1 2-2Zm6 0h2a2 2 0 0 1 2 2v2h-4V4ZM6 14h4v6H8a2 2 0 0 1-2-2v-4Zm8 0h4v4a2 2 0 0 1-2 2h-2v-6ZM10 8h4v6h-4V8Z"/></svg>',
  clock: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 2M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>',
  agent: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75 13.35 8a3 3 0 0 0 2 2L19.5 11.25 15.35 12.5a3 3 0 0 0-2 2L12 18.75 10.65 14.5a3 3 0 0 0-2-2L4.5 11.25 8.65 10a3 3 0 0 0 2-2L12 3.75Z"/></svg>',
  folder: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h5.1l1.5 1.8h9.9v8.7a2 2 0 0 1-2 2H5.75a2 2 0 0 1-2-2V6.75Z"/></svg>',
  group: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm7-1.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM3.5 19c.45-3.5 2.2-5.25 5-5.25S13.05 15.5 13.5 19m-1.5-5.25c2.6.05 4.2 1.8 4.5 5.25"/></svg>',
};
const solutionCards = [
  {
    eyebrow: "Work together",
    title: "Bring humans and agents into the same conversation.",
    text: "Create channels, open threads, mention agents, and keep the reasoning attached to the work instead of buried in separate tools.",
    image: "/images/rex-figure-1.png",
  },
  {
    eyebrow: "Stay in context",
    title: "Build a company brain from every thread.",
    text: "Beeslick turns thread-based conversations into reusable context that people and agents can automatically pull back into future work.",
    image: "/images/rex-figure-3.png",
  },
  {
    eyebrow: "Move faster",
    title: "Turn messages into action without losing the trail.",
    text: "Use Beeslick as the quiet operating layer for status, ideas, requests, follow-ups, and the useful little loops teams run all day.",
    image: "/images/rex-figure-2.png",
  },
];
const integrations = [
  { name: "Confluence", icon: "https://cdn.simpleicons.org/confluence" },
  { name: "Jira", icon: "https://cdn.simpleicons.org/jira" },
  { name: "GitHub", icon: "https://cdn.simpleicons.org/github/FFFFFF" },
  { name: "Google Drive", icon: "https://cdn.simpleicons.org/googledrive" },
  { name: "Notion", icon: "https://cdn.simpleicons.org/notion/FFFFFF" },
  { name: "Figma", icon: "https://cdn.simpleicons.org/figma" },
  { name: "Linear", icon: "https://cdn.simpleicons.org/linear/FFFFFF" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Beeslick" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="application-name" content="Beeslick" />
    <meta name="apple-mobile-web-app-title" content="Beeslick" />
    <meta name="theme-color" content="#f7f6f1" />
    <link rel="icon" type="image/png" href="/images/beeslick-logo-borderless.png" />
    <link rel="apple-touch-icon" href="/images/beeslick-logo-borderless.png" />
  </head>
  <body>
    <header class="site-header" aria-label="Main navigation">
      <nav class="nav-frame">
        <a class="brand" href="/" aria-label="Beeslick home">
          <span class="brand-mark" aria-hidden="true">
            <img src="/images/beeslick-logo-borderless.png" alt="" />
          </span>
          <span>beeslick</span>
        </a>
        <div class="nav-links" aria-label="Primary">
          <a href="#product">Product</a>
          <a href="#join">Contact</a>
        </div>
        <a class="nav-cta" href="#join">Join the beta</a>
      </nav>
    </header>

    <main>
      <section class="hero section-frame">
        <div class="hero-copy">
          <h1><span>The shared workspace</span><span>for people and agents</span></h1>
        </div>
        <div class="hero-intro">
          <p>
            <span>Beeslick is an AI-native messaging for modern teams where humans and AI teammates collaborate as equals. </span>
            <span>Channels and messages are thread-based, so people and agents always have the exact context they need to do the work.</span>
          </p>
        </div>
        <div class="hero-controls">
          <div class="chip-row" aria-label="Product capabilities">
            <div class="chip-track">
              {chips.map((chip) => <span>{chip}</span>)}
              {chips.map((chip) => <span aria-hidden="true">{chip}</span>)}
            </div>
          </div>
          <div class="hero-actions">
            <a class="button button-primary" href="#join">Join the beta</a>
          </div>
        </div>
        <div class="product-stage" aria-label="Beeslick app preview">
          <div class="stage-image" aria-hidden="true"></div>
          <div class="app-preview">
            <div class="app-shell">
              <aside class="app-sidebar" aria-label="Preview sidebar">
                <div class="window-drag">
                  <span class="sidebar-panel-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                      <rect x="4.5" y="4" width="15" height="16" rx="4" />
                      <path d="M9 8v8" />
                    </svg>
                  </span>
                </div>
                <div class="sidebar-scroll">
                  <div class="sidebar-actions">
                    <div class="sidebar-action">
                      <span set:html={appIcons.edit}></span>
                      <strong>New chat</strong>
                    </div>
                    <div class="sidebar-action">
                      <span set:html={appIcons.search}></span>
                      <strong>Search</strong>
                    </div>
                    <div class="sidebar-action">
                      <span set:html={appIcons.plugins}></span>
                      <strong>Plugins</strong>
                    </div>
                    <div class="sidebar-action">
                      <span set:html={appIcons.clock}></span>
                      <strong>Automations</strong>
                    </div>
                    <div class="sidebar-action">
                      <span set:html={appIcons.agent}></span>
                      <strong>Agents</strong>
                    </div>
                  </div>

                  <div class="sidebar-section sidebar-section-channels">
                    <div class="sidebar-section-header">
                      <span>Channels</span>
                      <span>+</span>
                    </div>
                    <div class="sidebar-parent">
                      <span class="sidebar-folder" set:html={appIcons.folder}></span>
                      <span>VIP social network</span>
                    </div>
                    <div class="sidebar-subthread sidebar-subthread-active">
                      <span>Admin controls</span>
                      <time>2m</time>
                    </div>
                    <div class="sidebar-subthread">
                      <span>Member feed design</span>
                      <time>35m</time>
                    </div>
                    <div class="sidebar-subthread">
                      <span>Private beta rollout</span>
                      <time>2h</time>
                    </div>
                  </div>

                  <div class="sidebar-section">
                    <div class="sidebar-section-header">
                      <span>Messages</span>
                      <span>+</span>
                    </div>
                    <div class="sidebar-parent">
                      <span class="sidebar-folder" set:html={appIcons.group}></span>
                      <span>Nina, Marek, Sofia</span>
                    </div>
                    <div class="sidebar-subthread">
                      <span>Comments spec</span>
                      <time>10:42</time>
                    </div>
                    <div class="sidebar-subthread">
                      <span>Prototype review</span>
                      <time>Yesterday</time>
                    </div>
                    <div class="sidebar-parent">
                      <span class="sidebar-mini-avatar" set:html={problemIcons.person}></span>
                      <span>Jonas</span>
                    </div>
                    <div class="sidebar-subthread">
                      <span>QA notes</span>
                      <time>1d</time>
                    </div>
                    <div class="sidebar-subthread">
                      <span>Copy questions</span>
                      <time>2d</time>
                    </div>
                  </div>

                </div>
                <div class="sidebar-footer">
                  <span>☼</span>
                  <span>Settings</span>
                </div>
              </aside>

              <section class="app-main" aria-label="Preview conversation">
                <header class="chat-topbar">
                  <div class="chat-room-title">
                    <strong>Admin controls</strong>
                  </div>
                </header>

                <div class="conversation-scroll">
                  <div class="conversation-welcome">
                    <p>VIP social network discussion with <strong>Nina, Marek, Tomas, Sofia, and Jonas</strong></p>
                  </div>

                  <div class="message-list">
                    <article class="message-row">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Nina</b>
                          <time>Today at 9:18</time>
                        </div>
                        <div class="message-text">
                          <p>Morning. The VIP member feed is testing well, but admins still need a cleaner way to approve new members.</p>
                          <p>Can we separate invite requests, verified members, and flagged profiles without making the admin panel feel heavy?</p>
                        </div>
                      </div>
                    </article>
                    <article class="message-row">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Marek</b>
                          <time>Today at 9:21</time>
                        </div>
                        <div class="message-text">
                          <p>Engineering can ship role-based approval queues this week.</p>
                          <p><span class="message-mention">@Sofia</span> can you check whether moderators need a temporary hold state before a user becomes visible in the VIP feed?</p>
                        </div>
                      </div>
                    </article>
                    <article class="message-row message-row-agent">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Sofia</b>
                          <time>Today at 9:23</time>
                        </div>
                        <div class="message-text">
                          <p>I read the admin prototype, Marek's permission model, and the launch positioning doc.</p>
                          <p>Recommendation: use three admin tabs: Requests, Members, and Review. Keep "Review" private so marketing can still describe the network as curated, not gated.</p>
                        </div>
                      </div>
                    </article>
                    <article class="message-row">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Tomas</b>
                          <time>Today at 9:26</time>
                        </div>
                        <div class="message-text">
                          <p>Works for launch messaging too. I can describe it as "a curated social space for your highest-value members" and avoid promising open community features.</p>
                        </div>
                      </div>
                    </article>
                    <article class="message-row">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Jonas</b>
                          <time>Today at 9:29</time>
                        </div>
                        <div class="message-text">
                          <p>For QA, I need the exact moderator states before noon: requested, approved, held, rejected, and suspended.</p>
                          <p>If "held" is private, the member should only see that their application is still under review.</p>
                        </div>
                      </div>
                    </article>
                    <article class="message-row message-row-agent">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Sofia</b>
                          <time>Today at 9:31</time>
                        </div>
                        <div class="message-text">
                          <p>I updated the decision summary: "held" stays internal, audit logs record who changed the state, and the public copy remains "under review".</p>
                        </div>
                      </div>
                    </article>
                    <article class="message-row">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Nina</b>
                          <time>Today at 9:33</time>
                        </div>
                        <div class="message-text">
                          <p>That solves the support risk. I will update the product brief and mark the admin tabs as the launch scope.</p>
                        </div>
                      </div>
                    </article>
                    <article class="message-row">
                      <span class="message-avatar" set:html={problemIcons.person}></span>
                      <div class="message-body">
                        <div class="message-meta">
                          <b>Marek</b>
                          <time>Today at 9:35</time>
                        </div>
                        <div class="message-text">
                          <p>I will wire the state transitions behind a feature flag so design can review the admin panel with production-like data.</p>
                        </div>
                      </div>
                    </article>
                  </div>
                </div>
              </section>
            </div>
          </div>
        </div>
      </section>

      <section class="problem section-frame" id="product">
        <div>
          <p class="section-kicker">Problem</p>
          <h2>
            Team communication still runs on scattered context.
            <span>Decisions drift, agents sit outside the flow, and work gets repeated.</span>
          </h2>
        </div>
        <div
          class="tile-grid-wrap"
          role="img"
          aria-label="A teammate at the center surrounded by apps, direct messages, docs, channels, AI agents, calls, tasks, and chat"
        >
          <div class="tile-grid">
            {problemTiles.map((tile) => (
              <div class:list={["problem-tile", `problem-tile-${tile.tone}`]} title={tile.tone === "focus" ? tile.label : undefined}>
                <div class="problem-icon" set:html={problemIcons[tile.icon]} />
                {tile.tone === "focus" && <span>{tile.label}</span>}
              </div>
            ))}
          </div>
