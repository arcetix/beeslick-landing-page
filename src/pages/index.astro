    font-display: swap;
  }

  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
  }

  :global(body) {
    --font-ui-size: 13px;
