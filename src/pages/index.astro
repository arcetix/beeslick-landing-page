  .pill-marquee {
    position: relative;
    z-index: 3;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0, #000 42px, #000 calc(100% - 42px), transparent 100%);
  }

  .pill-marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .pill-marquee-track span {
    position: relative;
    z-index: 4;
    flex: 0 0 auto;
    margin-right: 12px;
    padding: 10px 20px;
    color: #fff;
    white-space: nowrap;
    background: rgba(237, 235, 224, 0.48);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      0 10px 24px rgba(0, 0, 0, 0.12);
    font-size: 14px;
    font-weight: 650;
    line-height: 1.4;
    backdrop-filter: blur(12px);
  }

  .pill-marquee:nth-child(2) .pill-marquee-track span:nth-child(2n) {
    background: rgba(237, 235, 224, 0.72);
  }

  .pill-marquee-left .pill-marquee-track {
    animation: solution-pill-left 70s linear infinite;
  }

  .pill-marquee-right .pill-marquee-track {
    animation: solution-pill-right 95s linear infinite;
  }

  .pill-marquee-slow .pill-marquee-track {
    animation-duration: 110s;
  }

  .pill-marquee:hover .pill-marquee-track {
    animation-play-state: paused;
  }

  .case-panel {
    left: 50%;
    top: 50%;
    width: calc(100% - 24px);
    max-width: 333px;
    height: 148px;
    transform: translate(-50%, -50%);
    display: grid;
    gap: 14px;
    padding: 18px 22px;
    background: rgba(255, 255, 255, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      0 18px 40px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(14px);
  }

  .case-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .case-panel-header b {
    color: #fff;
    font-size: 12px;
    font-weight: 650;
    line-height: 1.2;
  }

  .case-thread {
    display: grid;
    gap: 7px;
  }

  .case-thread-option {
    display: flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    color: rgba(255, 255, 255, 0.74);
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    font-weight: 500;
    font-size: 12px;
    line-height: 1;
  }

  .case-thread-option-active {
    color: #fff;
    background: rgba(217, 162, 59, 0.2);
    border-color: rgba(217, 162, 59, 0.24);
  }

  .solution-card-copy {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    width: 100%;
    min-height: 160px;
    padding: 20px;
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.25));
    color: #fff;
    pointer-events: none;
  }

  .solution-card-body {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 32px;
    width: 100%;
  }

  .solution-card-body p {
    margin: 0;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0;
  }

  .solution-card-copy strong {
    display: inline;
    color: #fff;
    font-weight: 500;
  }

  .solution-card-body span {
    display: inline;
    color: rgba(255, 255, 255, 0.7);
  }

  @keyframes solution-pill-left {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @keyframes solution-pill-right {
    from {
      transform: translateX(-50%);
    }

    to {
      transform: translateX(0);
    }
  }

  .integrations {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 560px);
    gap: clamp(48px, 7vw, 96px);
    align-items: center;
    width: 100vw;
    max-width: none;
    min-height: 720px;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding-inline: max(var(--container-pad), calc((100vw - var(--container-width)) / 2 + var(--container-pad)));
    padding-block: clamp(86px, 12vw, 150px);
    color: #faf9f6;
    background: var(--footer-bg);
    border-top: 1px solid rgba(250, 249, 246, 0.08);
    border-inline: 0;
  }

  .integrations::before,
  .integrations::after {
    display: none;
  }

  .dark-kicker {
    display: flex;
    align-items: center;
    margin-bottom: 38px;
  }

  .dark-kicker p {
    margin: 0;
    color: rgba(250, 249, 246, 0.7);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.26px;
    text-transform: uppercase;
  }

  .integrations-copy h2 {
    max-width: 560px;
    margin: 0;
    color: #faf9f6;
    font-size: clamp(40px, 5vw, 58px);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.015em;
  }

  .integrations-copy h2 span {
    display: block;
    color: rgba(250, 249, 246, 0.48);
  }

  .integrations-copy > p {
    max-width: 440px;
    margin: 30px 0 0;
    color: rgba(250, 249, 246, 0.64);
    font-size: 15px;
    line-height: 1.55;
  }

  .integration-map {
    display: grid;
    grid-template-columns: auto minmax(80px, 144px) minmax(190px, 240px);
    align-items: center;
    justify-content: end;
    gap: 18px;
    min-width: 0;
  }

  .beeslick-node,
  .integration-pill {
    display: inline-flex;
    align-items: center;
    height: 56px;
    color: #faf9f6;
    background: rgba(250, 249, 246, 0.07);
    border-radius: 999px;
  }

  .beeslick-node {
    gap: 8px;
    padding: 0 26px 0 22px;
    color: #120f0c;
    background: #faf9f6;
    box-shadow: 0 0 80px rgba(250, 249, 246, 0.1);
  }

  .beeslick-node img {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }

  .beeslick-node span,
  .integration-pill strong {
    font-size: 15px;
    font-weight: 500;
    line-height: 1;
  }

  .integration-connector {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 8px;
    min-width: 80px;
  }

  .integration-connector span {
    width: 4px;
    height: 4px;
    background: #faf9f6;
    border-radius: 999px;
  }

  .integration-connector i {
    height: 1px;
    background: rgba(250, 249, 246, 0.34);
  }

  .integration-list {
    position: relative;
    overflow: hidden;
    height: 436px;
    min-width: 0;
  }

  .integration-list::before,
  .integration-list::after {
    position: absolute;
    inset-inline: 0;
    z-index: 2;
    height: 86px;
    content: "";
    pointer-events: none;
  }

  .integration-list::before {
    top: 0;
    background: linear-gradient(to bottom, var(--footer-bg) 0%, rgba(18, 15, 12, 0) 100%);
  }

  .integration-list::after {
    bottom: 0;
    background: linear-gradient(to top, var(--footer-bg) 0%, rgba(18, 15, 12, 0) 100%);
  }

  .integration-track {
    position: absolute;
    inset-inline: 0;
    top: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    animation: integrations-marquee 28s linear infinite;
    will-change: transform;
  }

  .integration-list:hover .integration-track {
    animation-play-state: paused;
  }

  .integration-pill {
    flex: 0 0 auto;
    gap: 8px;
    width: max-content;
    max-width: 100%;
    padding: 0 28px 0 22px;
    transition: background 180ms ease, transform 180ms ease;
  }

  .integration-pill:hover {
    background: rgba(250, 249, 246, 0.12);
    transform: translateX(-2px);
  }

  .integration-pill span {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    background: rgba(250, 249, 246, 0.08);
    border: 1px solid rgba(250, 249, 246, 0.08);
    border-radius: 999px;
  }

  .integration-pill span img {
    width: 17px;
    height: 17px;
    object-fit: contain;
  }

  @keyframes integrations-marquee {
    from {
      transform: translateY(0);
    }

    to {
      transform: translateY(-50%);
    }
  }

  .booking {
    padding-block: clamp(96px, 13vw, 180px);
    border-top: 1px solid var(--line);
  }

  .booking-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 1fr);
    overflow: hidden;
    background: #f5f4f0;
    border: 1px solid rgba(24, 21, 15, 0.1);
    border-radius: var(--radius-sm);
  }

  .booking-story {
    min-height: 600px;
    padding: 40px;
    color: #f7f4ee;
    background:
      radial-gradient(circle at center, rgba(247, 244, 238, 0.18) 0 1px, transparent 1.5px) 0 0 / 12px 12px,
      linear-gradient(135deg, #2a2112, var(--dark));
  }

  .duration {
    display: inline-flex;
    margin-bottom: 20px;
    padding: 6px 12px;
    color: rgba(247, 244, 238, 0.82);
    border: 1px solid rgba(247, 244, 238, 0.2);
    border-radius: 999px;
    font-size: 12px;
    line-height: 1;
  }

  .booking-story h2 {
