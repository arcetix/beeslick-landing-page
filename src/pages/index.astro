    --composer-icon-color: #d2dbea;
    --composer-icon-hover-bg: rgba(148, 163, 184, 0.22);
    --composer-icon-hover-color: #f8fafc;
    --composer-placeholder-color: var(--text-muted);
    --composer-status-row-color: #aeb4bd;
    --composer-status-chip-color: #b8bec8;
    --settings-menu-border: rgba(161, 161, 161, 0.28);
    --settings-menu-bg: rgba(28, 28, 28, 0.95);
    --settings-menu-shadow: 0 20px 40px rgba(0, 0, 0, 0.48);
    --settings-profile-color: #c7c7c7;
    --settings-profile-muted: #a7a7a7;
    --settings-menu-item-color: #efefef;
    --settings-menu-item-hover: rgba(161, 161, 161, 0.13);
    --mobile-scroll-hint-bg: rgba(24, 24, 24, 1);
    --mobile-scroll-hint-border: rgba(161, 161, 161, 0.26);

    font-family: "Denim", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text-primary);
    background-color: #d9c89f;
    position: relative;
  }

  :global(body.theme-light) {
    --bg-primary: #ffffff;
    --bg-secondary: #f7f8f9;
    --bg-cool: #eeeff3;
    --bg-brand-dark: #c78400;
    --sidebar-bg: rgba(245, 246, 250, 0.74);
    --sidebar-glass-tint: rgba(248, 250, 255, 0.62);
    --sidebar-hover: rgba(15, 23, 42, 0.06);
    --sidebar-active-bg: rgba(253, 178, 13, 0.16);
    --shell-bg: rgba(255, 255, 255, 0.9);
    --msg-hover: rgba(15, 23, 42, 0.03);
    --divider: rgba(15, 23, 42, 0.1);
    --glass-bg: rgba(255, 255, 255, 0.78);
    --text-primary: #1f2937;
    --text-secondary: #6b7280;
    --text-bright: #1f2937;
    --text-muted: #6f7485;
    --composer-input-bg: rgba(255, 255, 255, 0.34);
    --composer-input-border: rgba(15, 23, 42, 0.12);
    --composer-input-border-focus: rgba(63, 67, 83, 0.34);
    --chat-view-border: rgba(15, 23, 42, 0.08);
    --layout-glow-1: rgba(251, 191, 36, 0.16);
    --layout-glow-2: rgba(217, 119, 6, 0.12);

    --app-window-border: rgba(148, 163, 184, 0.28);
    --app-window-bg: #ffffff;
    --app-window-shadow: 0 26px 58px rgba(15, 23, 42, 0.22);
    --sidebar-shadow: none;
    --sidebar-item-icon-color: #8f96a3;
    --subthread-color: #505869;
    --subthread-hover-bg: rgba(255, 255, 255, 0.42);
    --subthread-hover-color: #1f2937;
    --subthread-active-bg: rgba(255, 255, 255, 0.62);
    --subthread-active-color: #111827;
    --subthread-time-color: #8f96a3;
    --composer-format-color: #61646b;
    --composer-icon-color: #595b61;
    --composer-icon-hover-bg: rgba(15, 23, 42, 0.06);
    --composer-icon-hover-color: #36383d;
    --composer-placeholder-color: var(--text-muted);
    --composer-status-row-color: #7d8594;
    --composer-status-chip-color: #6f7485;
    --settings-menu-border: rgba(148, 163, 184, 0.32);
    --settings-menu-bg: rgba(246, 247, 249, 0.95);
    --settings-menu-shadow: 0 20px 40px rgba(15, 23, 42, 0.16);
    --settings-profile-color: #6b7280;
    --settings-profile-muted: #81858f;
    --settings-menu-item-color: #111827;
    --settings-menu-item-hover: rgba(15, 23, 42, 0.06);
    --mobile-scroll-hint-bg: rgba(246, 247, 249, 0.98);
    --mobile-scroll-hint-border: rgba(148, 163, 184, 0.42);
    background-color: #1f1703;
  }

  .grain-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-position: 0 0;
    background-size: 200px 200px;
    background-repeat: repeat;
    z-index: 0;
  }

  .grain-layer--dark {
    background-image: url("https://res.cloudinary.com/dmukukwp6/image/upload/keyboard_garden_bg_dark_9ab088797a.png");
    opacity: var(--grain-dark-opacity, 1);
  }

  .grain-layer--light {
    background-image: url("https://res.cloudinary.com/dmukukwp6/image/upload/keyboard_garden_bg_light_03a349af5c.png");
    opacity: var(--grain-light-opacity, 0.2);
  }

  button,
  input {
    font: inherit;
    color: inherit;
  }

  button {
    border: 0;
    background: none;
    cursor: pointer;
  }

  input {
    border: 0;
    outline: 0;
    background: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .liquid-filter-defs {
    position: absolute;
    inline-size: 0;
    block-size: 0;
    pointer-events: none;
  }

  .landing-shell {
    position: relative;
    z-index: 1;
    width: 100vw;
    height: 100vh;
    height: 100svh;
    padding: 32px;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    justify-items: center;
    gap: 0;
  }

  .app-window {
    width: 85%;
    min-width: 0;
    height: 90%;
    margin: 0 auto;
    position: relative;
    left: var(--drag-x, 0px);
    top: var(--drag-y, 0px);
    border-radius: 16px;
    border: 1px solid var(--app-window-border);
    background: var(--app-window-bg);
    overflow: hidden;
    box-shadow: var(--app-window-shadow);
    animation: shell-float 22s ease-in-out infinite alternate;
  }

  .window-dots {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .window-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }

  .window-dot--red {
    background: #ff5f57;
  }

  .window-dot--yellow {
    background: #ffbd2f;
  }

  .window-dot--green {
    background: #28c840;
  }

  @keyframes shell-float {
    0% {
      transform: translateY(0px);
    }
    100% {
      transform: translateY(-5px);
    }
  }

  .layout {
    position: relative;
    display: flex;
    min-width: 0;
    height: 100%;
    min-height: 0;
    overflow: hidden;
    border-radius: var(--radius-shell);
    background: var(--sidebar-bg);
    color: var(--text-primary);
  }

  .layout::before {
    content: none;
  }

  .layout > * {
    position: relative;
    z-index: 1;
  }

  .sidebar {
    width: 292px;
    background: var(--sidebar-bg);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    height: 100%;
    overflow: hidden;
    box-shadow: var(--sidebar-shadow);
    border-top-left-radius: var(--radius-shell);
    border-bottom-left-radius: var(--radius-shell);
  }

  .sidebar-drag {
    height: 32px;
    flex-shrink: 0;
    padding: 0 8px 0 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  [data-window-drag] {
    cursor: grab;
    user-select: none;
    touch-action: none;
  }

  :global(body.is-dragging-window) {
    user-select: none;
  }

  :global(body.is-dragging-window) [data-window-drag] {
    cursor: grabbing;
  }

  .sidebar-collapse-btn {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #bebebe;
  }

  .sidebar-collapse-btn:hover {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .sidebar-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 0 10px;
    scrollbar-width: none;
  }

  .sidebar-scroll::-webkit-scrollbar {
    width: 0;
    height: 0;
  }

  .sidebar-section {
    margin-top: 120px;
  }

  .sidebar-section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 24px 8px 16px;
    font-size: 13px;
    color: #8a8f98;
    letter-spacing: 0.05em;
  }

  .sidebar-section-header--direct {
    margin-top: 20px;
  }

  .sidebar-section-label {
    font-size: 13px;
    font-weight: 400;
    color: #8a8f98;
  }

  .sidebar-section-label-icon {
    width: 14px;
    color: var(--text-muted);
    text-align: center;
  }

  .sidebar-threads-actions {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .sidebar-add {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: var(--text-muted);
  }

  .sidebar-add:hover {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .sidebar-filter {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--text-muted);
  }

  .sidebar-filter:hover {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .sidebar-item {
    display: flex;
    align-items: center;
    gap: 7px;
    width: 100%;
    padding: 5px 16px;
    text-align: left;
    color: var(--text-secondary);
    font-size: 13px;
    cursor: text;
    transition: background 0.22s ease, color 0.22s ease;
  }

  .sidebar-item:hover {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .sidebar-item--locked {
    cursor: not-allowed;
    position: relative;
    color: var(--text-secondary);
  }

  .sidebar-item--locked .sidebar-item-icon {
    color: var(--sidebar-item-icon-color);
    opacity: 0.95;
  }

  .sidebar-item--locked:hover {
    background: transparent;
    color: var(--text-secondary);
  }

  .sidebar-item-tooltip {
    position: absolute;
    left: 14px;
    right: 14px;
    top: calc(100% + 14px);
    width: auto;
    max-width: none;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid var(--settings-menu-border);
    background: var(--settings-menu-bg);
    box-shadow: var(--settings-menu-shadow);
    color: var(--settings-menu-item-color);
    font-size: 12px;
    line-height: 1.45;
    white-space: normal;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.14s ease, transform 0.14s ease, visibility 0.14s ease;
    z-index: 9;
  }

  .sidebar-item--locked:hover .sidebar-item-tooltip,
  .sidebar-item--locked:focus-visible .sidebar-item-tooltip,
  .sidebar-item--locked.is-tooltip-open .sidebar-item-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .sidebar-item--active {
    background: transparent;
    color: var(--text-secondary);
  }

  .sidebar-item-hash {
    font-size: 16px;
    opacity: 0.6;
    flex-shrink: 0;
  }

  .sidebar-item-icon {
    width: 16px;
    height: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--sidebar-item-icon-color);
    opacity: 0.95;
    flex-shrink: 0;
  }

  .sidebar-item-icon svg {
    display: block;
  }

  .sidebar-item-icon .icon-expanded {
    display: none;
  }

  .sidebar-item--expanded .sidebar-item-icon .icon-collapsed {
    display: none;
  }

  .sidebar-item--expanded .sidebar-item-icon .icon-expanded {
    display: block;
  }

  .sidebar-item-icon path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .sidebar-item-ai-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--bg-brand-main);
    flex-shrink: 0;
  }

  .sidebar-item-name {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 13px;
  }

  .sidebar-dm-label {
    flex: 1;
    min-width: 0;
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }

  .sidebar-dm-count {
    min-width: 22px;
    height: 22px;
    padding: 0 7px;
    border-radius: 7px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #535663;
    color: #f8fafc;
    font-size: 14px;
    font-weight: 600;
    line-height: 1;
    flex-shrink: 0;
  }

  .sidebar-dm-names {
    min-width: 0;
  }

  .sidebar-thread-list {
    margin: 6px 14px 8px 32px;
    padding-left: 0;
    display: block;
  }

  .sidebar-thread-list-inner {
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-subthread-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    width: 100%;
    padding: 5px 10px;
    border-radius: 10px;
    text-align: left;
    color: var(--subthread-color);
    font-size: var(--font-ui-size);
    line-height: 1.35;
    font-weight: var(--font-ui-weight);
    cursor: text;
    transition: background 0.12s ease, color 0.12s ease;
  }

  .sidebar-subthread-main {
    flex: 1;
    min-width: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .sidebar-subthread-item:hover {
    background: var(--subthread-hover-bg);
    color: var(--subthread-hover-color);
  }

  .sidebar-subthread-item--active {
    background: var(--subthread-active-bg);
    color: var(--subthread-active-color);
  }

  .sidebar-subthread-title {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-subthread-time {
    min-width: 52px;
    text-align: right;
    font-size: var(--font-ui-size);
    color: var(--subthread-time-color);
    flex-shrink: 0;
  }

  .sidebar-activity {
    margin: 10px 0 0;
    display: flex;
    flex-direction: column;
  }

  .sidebar-activity-item {
    width: 100%;
    padding: 8px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    font-size: 13px;
    color: #d9d9d9;
    text-align: left;
  }

  .sidebar-activity-main {
    flex: 1;
    min-width: 0;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .sidebar-activity-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ffbb1c;
    flex-shrink: 0;
  }

  .sidebar-activity-text {
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar-activity-time {
    flex-shrink: 0;
    color: #d0d0d0;
  }

  .sidebar-activity-item:hover {
    background: var(--sidebar-hover);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot--online {
    background: var(--status-online);
  }

  .sidebar-footer {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    gap: 10px;
    flex-shrink: 0;
  }

  .sidebar-settings-wrap {
    flex: 1;
    position: relative;
  }

  .sidebar-settings-wrap--open .sidebar-settings-btn {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .sidebar-settings-btn {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 6px;
    width: 100%;
    padding: 5px 8px;
    border-radius: 6px;
    color: var(--text-secondary);
    font-size: var(--font-ui-size);
    font-weight: var(--font-ui-weight-medium);
    text-align: left;
    transition: background 0.1s, color 0.1s;
  }

  .sidebar-settings-btn:hover {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .sidebar-settings-btn:focus-visible,
  .sidebar-settings-menu-item:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.48);
    outline-offset: 2px;
  }

  .sidebar-settings-menu {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc(100% + 10px);
    border-radius: 16px;
    border: 1px solid var(--settings-menu-border);
    background: var(--settings-menu-bg);
    box-shadow: var(--settings-menu-shadow);
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 0;
    z-index: 8;
    backdrop-filter: blur(8px) saturate(130%);
    -webkit-backdrop-filter: blur(8px) saturate(130%);
  }

  .sidebar-settings-menu[hidden] {
    display: none !important;
  }

  .sidebar-settings-profile {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 2px;
  }

  .sidebar-settings-profile-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 4px 6px;
    border-radius: 10px;
    color: var(--settings-profile-color);
    font-size: var(--font-ui-size);
    font-weight: var(--font-ui-weight);
    min-height: 34px;
  }

  .sidebar-settings-profile-row svg,
  .sidebar-settings-menu-item-main svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .sidebar-settings-profile-row--muted {
    color: var(--settings-profile-muted);
  }

  .sidebar-settings-divider {
    height: 1px;
    margin: 6px 0;
    background: rgba(161, 161, 161, 0.24);
  }

  .sidebar-settings-menu-item {
    min-height: 34px;
    border-radius: 10px;
    padding: 4px 6px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    color: var(--settings-menu-item-color);
    font-size: var(--font-ui-size);
    font-weight: var(--font-ui-weight);
    transition: background 0.12s ease, color 0.12s ease;
  }

  .sidebar-settings-menu-item:hover {
    background: var(--settings-menu-item-hover);
  }

  .sidebar-settings-menu-item-main {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .sidebar-settings-menu-item-main span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .main-shell {
    flex: 1;
    display: flex;
    min-width: 0;
    background: var(--shell-bg);
    border-radius: var(--radius-shell);
    overflow: hidden;
  }

  .chat-view {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--main-bg);
    --content-max-width: 980px;
    --content-side-gap: 28px;
    position: relative;
  }

  .glass {
    position: relative;
    overflow: hidden;
    background: var(--glass-bg);
    backdrop-filter: blur(20px) saturate(160%) brightness(1.02);
    -webkit-backdrop-filter: blur(20px) saturate(160%) brightness(1.02);
  }

  .glass::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.2) 50%, transparent 100%);
    pointer-events: none;
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 13px var(--content-side-gap);
    flex-shrink: 0;
  }

  .chat-mobile-toggle {
    display: none;
    width: 30px;
    height: 30px;
    border-radius: 6px;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    flex-shrink: 0;
    transition: background 0.12s ease, color 0.12s ease;
  }

  .chat-mobile-toggle:hover {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .chat-header-hash {
    font-size: 17px;
    color: var(--text-muted);
  }

  .chat-header-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    overflow: hidden;
    flex: 1;
  }

  .chat-header-title {
    font-size: 15px;
    color: var(--text-bright);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .chat-header-subtitle {
    font-size: 12px;
    color: var(--text-secondary);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .header-action-btn {
    width: 30px;
    height: 30px;
    border-radius: 6px;
    color: var(--text-secondary);
  }

  .header-action-btn:hover {
    background: var(--sidebar-hover);
    color: var(--text-primary);
  }

  .message-list {
    flex: 1;
    overflow-y: auto;
    padding: 0 0 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.1) transparent;
  }

  .message-list::-webkit-scrollbar {
    width: 5px;
  }

  .message-list::-webkit-scrollbar-track {
    background: transparent;
  }

  .message-list::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 3px;
  }

  .channel-welcome {
    width: min(calc(100% - (var(--content-side-gap) * 2)), var(--content-max-width));
    margin: 0 auto 12px;
    padding: 32px 4px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .channel-welcome-hash {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--sidebar-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: var(--text-secondary);
    margin-bottom: 4px;
  }

  .channel-welcome h1 {
    margin: 0;
    font-size: 22px;
    font-weight: 600;
  }

  .channel-welcome p {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .message {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    width: min(calc(100% - (var(--content-side-gap) * 2)), var(--content-max-width));
    margin: 0 auto;
    padding: 3px 4px;
    border: 1px solid transparent;
    border-radius: 10px;
    cursor: text;
    transition: background 0.24s ease, border-color 0.24s ease;
  }

  .message + .message {
    margin-top: 10px;
  }

  .message + .message--grouped {
    margin-top: 2px;
  }

  .message--grouped {
    padding-left: 47px;
  }

  .message:hover {
    background: var(--msg-hover);
    border-color: rgba(var(--brand-rgb), 0.34);
  }

  .typing-indicator,
  .typing-indicator:hover {
    border-color: transparent;
    background: transparent;
  }

  .typing-indicator-label {
    font-size: 12px;
    color: var(--text-muted);
  }

  .typing-bubble {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 0;
    border: none;
    background: transparent;
  }

  .typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-muted);
    animation: typing-pulse 1.1s infinite ease-in-out;
  }

  .typing-dot:nth-child(2) {
    animation-delay: 0.14s;
  }

  .typing-dot:nth-child(3) {
    animation-delay: 0.28s;
  }

  @keyframes typing-pulse {
    0%,
    80%,
    100% {
      transform: translateY(0);
      opacity: 0.35;
    }

    40% {
      transform: translateY(-3px);
      opacity: 1;
    }
