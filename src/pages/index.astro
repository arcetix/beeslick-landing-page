    align-items: center;
    justify-content: space-between;
    min-height: 40px;
    padding: 0 8px 0 10px;
  }

  .composer-actions > div {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .composer-actions .round-plus {
    width: 28px;
    height: 28px;
    margin-right: 4px;
    color: var(--app-text-primary);
    background: rgba(217, 162, 59, 0.15);
    border-radius: 999px;
    font-size: 18px;
    line-height: 1;
  }

  .composer-contextbar {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 7px 12px 0;
    color: var(--app-text-secondary);
    font-size: 11.5px;
  }

  .access-chip {
    color: var(--secondary);
  }

  .problem {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: clamp(44px, 9vw, 140px);
    align-items: center;
    padding-block: clamp(90px, 13vw, 180px);
    border-top: 1px solid var(--line);
  }

  .problem h2,
  .solution h2 {
    margin: 0;
    font-size: 42px;
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .tile-grid-wrap {
    --tile-ink: rgba(59, 42, 5, 0.56);
    --tile-muted-ink: rgba(59, 42, 5, 0.18);
    position: relative;
    flex-shrink: 0;
  }

  .tile-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, 75px);
    gap: 7px;
    width: max-content;
  }

  .problem-tile {
    position: relative;
    width: 75px;
    height: 75px;
    overflow: hidden;
    display: grid;
    place-items: center;
    color: var(--tile-muted-ink);
    background: #f4f2ef;
    border-radius: 9px;
  }

  .problem-tile-focus {
    cursor: default;
    color: var(--tile-ink);
    background: #fff;
    box-shadow: inset 0 0 0 1px rgba(8, 5, 0, 0.07);
  }

  .problem-tile-center {
    color: rgba(255, 251, 237, 0.86);
    background: #3b2a05;
    box-shadow: inset 0 0 0 1px rgba(250, 249, 246, 0.08);
  }

  .problem-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    transform: translate(-50%, -50%);
    transition: opacity 0.2s ease;
  }

  .problem-icon svg {
    width: 28px;
    height: 28px;
  }

  .problem-icon svg [stroke="rgba(4,36,43,0.55)"] {
    stroke: var(--tile-ink);
  }

  .problem-icon svg [fill="rgba(4,36,43,0.55)"] {
    fill: var(--tile-ink);
  }

  .problem-icon svg [stroke="rgba(4,36,43,0.16)"] {
    stroke: var(--tile-muted-ink);
  }

  .problem-tile-center .problem-icon svg {
    width: 28px;
    height: 28px;
  }

  .problem-tile span {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 0 8px;
    color: #3b2a05;
    opacity: 0;
    font-size: 10px;
    font-weight: 650;
    line-height: 1.3;
    letter-spacing: 0.4px;
    text-align: center;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }

  .problem-tile-focus:hover .problem-icon {
    opacity: 0;
  }

  .problem-tile-focus:hover span {
    opacity: 1;
  }

  .tile-connector {
    position: absolute;
    inset: 0;
    width: 239px;
    height: 239px;
    pointer-events: none;
  }

  .solution {
    padding-block: clamp(86px, 12vw, 160px);
    border-top: 1px solid var(--line);
  }

  .solution h2 {
    max-width: 1180px;
  }

  .solution-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: clamp(58px, 7vw, 96px);
  }

  .solution-card {
    min-width: 0;
  }

  .card-media {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    width: 100%;
    height: 560px;
    background: #120f0c;
    border-radius: 4px;
  }

  .card-media::before,
  .card-media::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
  }

  .card-media::before {
    background: linear-gradient(150deg, rgba(0, 0, 0, 0.55) 0%, transparent 60%);
    z-index: 1;
  }

  .card-media::after {
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.6), transparent 58%);
    z-index: 1;
  }

  .card-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    color: transparent;
    opacity: 0.9;
    filter: saturate(0.86) contrast(1.04);
    transform: scale(1.01);
  }

  .card-media[data-card="1"] img {
    opacity: 0.88;
    filter: saturate(0.84) contrast(1.04);
  }

  .solution-card-top {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    padding: 20px;
  }

  .solution-card-top p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0.26px;
    text-transform: uppercase;
  }

  .card-dot-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
  }

  .card-dot-row span {
    display: block;
    width: 3.847px;
    height: 3.847px;
    flex-shrink: 0;
    background: rgba(250, 249, 246, 0.5);
    border-radius: 999px;
  }

  .floating-note,
  .floating-stack,
  .case-panel {
    position: absolute;
    z-index: 4;
    color: #fff;
  }

  .floating-note {
    left: 50%;
    top: 50%;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    width: calc(100% - 40px);
    max-width: 333px;
    height: 148px;
    padding: 12px;
    transform: translate(-50%, -50%);
    background: rgba(237, 235, 224, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    backdrop-filter: blur(20px);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
  }

  .floating-note > span:first-child {
    width: 100%;
  }

  .floating-note-tag {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin: 0;
    padding: 4px 8px;
    color: #fff;
    vertical-align: baseline;
    background: rgba(237, 235, 224, 0.2);
    border-radius: 7px;
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
  }

  .floating-note-tag::before {
    content: "@";
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
    line-height: 1;
  }

  .floating-note-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    width: max-content;
    margin: 0;
    padding: 4px 8px;
    max-width: 100%;
    color: #7db5ff;
    vertical-align: baseline;
    background: rgba(34, 113, 209, 0.18);
    border-radius: 7px;
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
  }

  .floating-note-link::before {
    content: none;
  }

  .floating-note-link svg {
    width: 13px;
    height: 13px;
    flex: 0 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .floating-note-tooltip {
    cursor: help;
  }

  .floating-note-tooltip::after {
    position: absolute;
    left: 0;
    bottom: calc(100% + 8px);
    z-index: 8;
    width: max-content;
    max-width: 240px;
    padding: 8px 10px;
    color: #fffdfa;
    background: rgba(15, 12, 11, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
    content: attr(data-tooltip);
    font-size: 11px;
    font-weight: 500;
    line-height: 1.35;
    opacity: 0;
    pointer-events: none;
    transform: translateY(4px);
    transition: opacity 150ms ease, transform 150ms ease;
    white-space: normal;
  }

  .floating-note-tooltip:hover::after,
  .floating-note-tooltip:focus-visible::after {
    opacity: 1;
    transform: translateY(0);
  }

  .floating-note-arrow {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    color: #04242b;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 999px;
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.16);
  }

  .floating-note-arrow svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .floating-stack {
    inset: 116px 0 190px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    overflow: hidden;
    isolation: isolate;
  }

